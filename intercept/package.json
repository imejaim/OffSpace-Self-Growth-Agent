{
  "name": "intercept",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build:cf": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "start": "next start",
    "lint": "eslint",
    "teatime:create": "python ../scripts/teatime-skeleton.py",
    "teatime:validate": "python ../scripts/teatime-skeleton.py --validate",
    "teatime:fetch-images": "python ../scripts/teatime-fetch-images.py",
    "teatime:archive": "python ../scripts/teatime-md-to-archive.py",
    "teatime:intercept": "python ../scripts/teatime-intercept-publish.py"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@paypal/react-paypal-js": "^9.1.0",
    "@portone/browser-sdk": "^0.1.3",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.74",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.81.1"
  }
}
