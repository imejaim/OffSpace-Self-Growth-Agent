# ============================================
# OffSpace Self Growth Agent — 환경변수 템플릿
# 실제 값을 넣은 후 .env로 저장하세요
# ⚠️ .env 파일은 절대 git에 커밋하지 마세요
# ============================================

# --- PayPal 결제 (클라이언트 사이드, Next.js) ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your_paypal_client_id_here"

# --- 서버 환경변수 (.env.local에 함께 저장) ---
# 아래 변수들은 서버 사이드에서만 사용 (NEXT_PUBLIC_ 없음 = 클라이언트 노출 안됨)
# PAYPAL_CLIENT_ID="your_paypal_client_id"
# PAYPAL_CLIENT_SECRET="your_paypal_client_secret"
# PAYPAL_MODE="sandbox"  # 또는 "production"

# --- Gemini API (서버 사이드) ---
GEMINI_API_KEY="your_gemini_api_key_here"

# --- 앱 설정 ---
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"  # 프로덕션 시 실제 도메인으로 변경
